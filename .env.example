# 네이버 개발자 센터 > 애플리케이션 > Client ID / Secret (보조: 쇼핑 검색)
# 사용 API에 "검색" 추가 필요
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 브랜드커넥트 상품 URL 수집용 (필수)
# 1) https://brandconnect.naver.com 로그인
# 2) DevTools > Network 요청 헤더의 Cookie 전체를 복사
# 3) 아래에 붙여넣기 (따옴표 없이 한 줄)
BRANDCONNECT_COOKIE=

# 프로덕션(GitHub Pages)에서 호출할 API Worker URL (끝 슬래시 없이)
# 예: https://moneymaker-api.example.workers.dev
VITE_API_BASE=
